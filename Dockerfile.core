FROM rust:1.88-bookworm@sha256:af306cfa71d987911a781c37b59d7d67d934f49684058f96cf72079c3626bfe0 AS builder
WORKDIR /app
ARG UPRAVA_GIT_SHA=unknown
ENV CARGO_BUILD_JOBS=1 \
    CARGO_INCREMENTAL=0 \
    UPRAVA_BUILD_GIT_SHA=${UPRAVA_GIT_SHA}
COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/app/target,sharing=locked \
    cargo build --locked --release -p uprava-server --bin uprava-server \
    && cp /app/target/release/uprava-server /app/uprava-server

FROM debian:bookworm-slim@sha256:60eac759739651111db372c07be67863818726f754804b8707c90979bda511df
RUN groupadd --system --gid 10001 uprava \
    && useradd --system --uid 10001 --gid uprava --home-dir /var/lib/uprava \
        --create-home --shell /usr/sbin/nologin uprava \
    && install -d -o uprava -g uprava /data /var/lib/uprava/.local/share \
        /var/lib/uprava/.local/state /var/lib/uprava/.local/logs
COPY --from=builder --chown=0:0 /app/uprava-server /usr/local/bin/uprava-server
COPY --from=builder --chown=0:0 /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
ENV HOME=/var/lib/uprava \
    XDG_DATA_HOME=/var/lib/uprava/.local/share \
    UPRAVA_DATABASE_URL=sqlite:///data/core.sqlite \
    UPRAVA_CORE_LOG_FILE=/data/core.log \
    UPRAVA_CLIENT_LOG_FILE=/data/client.log
USER uprava
EXPOSE 8080
CMD ["uprava-server"]
