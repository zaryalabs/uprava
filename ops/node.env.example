UPRAVA_CORE_URL=https://uprava.zrya.io
UPRAVA_NODE_DISPLAY_NAME=Zarya Server
UPRAVA_NODE_HEARTBEAT_SECONDS=5
UPRAVA_NODE_STATE_PATH=/var/lib/uprava-node/node.sqlite
HOME=/var/lib/uprava
UPRAVA_CODEX_IGNORE_USER_CONFIG=true
UPRAVA_NODE_WORKSPACES=/srv/uprava-workspaces
UPRAVA_NODE_LOG_FILE=/var/lib/uprava-node/node.log
UPRAVA_CODEX_BINARY=/opt/codex/bin/codex
UPRAVA_CODEX_TIMEOUT_SECONDS=86400
UPRAVA_TOOLHIVE_URL=http://127.0.0.1:18081
UPRAVA_TOOLHIVE_TIMEOUT_SECONDS=300
UPRAVA_OPENSANDBOX_URL=http://127.0.0.1:18083
UPRAVA_TASK_RUNTIME_IMAGE=uprava/codex-runtime:0.2.20
