FROM node:24-bookworm-slim@sha256:cb4e8f7c443347358b7875e717c29e27bf9befc8f5a26cf18af3c3dec80e58c5
ARG CODEX_VERSION=0.144.1
ARG UPRAVA_VERSION=0.2.20
LABEL org.opencontainers.image.title="Uprava Codex task runtime" \
    org.opencontainers.image.version="${UPRAVA_VERSION}"
RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
        bash build-essential ca-certificates curl git jq pkg-config ripgrep \
    && npm install --global "@openai/codex@${CODEX_VERSION}" \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid 10001 task \
    && useradd --system --uid 10001 --gid task --home-dir /home/task \
        --create-home --shell /bin/sh task
ENV HOME=/home/task \
    CODEX_HOME=/home/task/.codex
WORKDIR /workspace
# OpenSandbox bootstraps execd as root. Uprava supplies the bind-mount owner's
# uid/gid for every Codex/check command, so task work itself is unprivileged.
CMD ["tail", "-f", "/dev/null"]
